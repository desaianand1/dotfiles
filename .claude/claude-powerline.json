{
  "theme": "tokyo-night",
  "display": {
    "style": "powerline",
    "colorCompatibility": "auto",
    "segments": {
      "directory": { "enabled": true, "showBasename": true },
      "git": {
        "enabled": true,
        "showSha": false,
        "showWorkingTree": true,
        "showOperation": true,
        "showTag": true,
        "showTimeSinceCommit": true,
        "showStashCount": true,
        "showUpstream": true,
        "showRepoName": true
      },
      "model": { "enabled": true },
      "session": { "enabled": false },
      "block": { "enabled": false },
      "context": { "enabled": true, "showPercentageOnly": true }
    }
  },
  "colors": {
    "tokyo-night": {
      "directory": { "bg": "#1a1b26", "fg": "#c0caf5" },
      "git": { "bg": "#24283b", "fg": "#9ece6a" },
      "model": { "bg": "#1a1b26", "fg": "#7aa2f7" },
      "context": { "bg": "#24283b", "fg": "#bb9af7" }
    }
  },
  "modelContextLimits": {
    "sonnet": 200000,
    "opus": 200000
  }
}
