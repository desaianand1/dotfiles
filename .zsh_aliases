# --- [IMPORTANT] kitty terminal workaround for SSH xterm compatibility ---
# See for context: https://github.com/kovidgoyal/kitty/issues/713#issuecomment-750704294
#

alias ssh='kitty +kitten ssh'

# --- end kitty SSH ---

# --- dotfiles repo work tree ---
# Exit if not running interactively
[[ $- != *i* ]] && return

# --- dotfiles ---
alias dotfiles='/usr/bin/git --git-dir=/Users/anand/dotfiles/ --work-tree=/Users/anand'
# -- end dotfiles ---

# --- custom ---
alias projects='${HOME}/Developer/Projects/'
# --- end custom ---

# --- bat ---
alias cat='bat'
# --- end bat ---

# --- fzf ---
alias fcat='fzf --preview "bat --color=always {}" --preview-window "~3"'
# --- end fzf ---

# --- eza ---
if ! type eza >/dev/null 2>&1; then
  print 'eza not found. Please install eza before using this plugin or use the zsh-ls plugin.' >&2
  return 1
fi

alias ls='eza -F -gh --group-directories-first --git --git-ignore --icons --color-scale all --hyperlink'
alias lh='ls -d .*'
alias lD='ls -D'
alias lc='ls -1'

alias ll='ls -l'
alias la='ll -a'

if [[ "$EZA_ENABLE_SORT_ALIASES" = 1 ]]; then
  alias lA='ll --sort=acc'
  alias lC='ll --sort=cr'
  alias lM='ll --sort=mod'
  alias lS='ll --sort=size'
  alias lX='ll --sort=ext'
  alias llm='lM'
fi

if [[ "$EZA_ENABLE_EXTENDED_ALIASES" = 1 ]]; then
  alias l='la -a'
  alias lsa='l'
  alias lx='l -HimUuS'
  alias lxa='lx -Z@'
fi

alias lt='ls -T'
alias tree=lt
# --- end eza ---

# --- Typora ---
alias typora="open -a typora"
# --- end Typora ---

# --- New tool replacements ---
alias top='btop'
alias du='dust'
alias df='duf'
alias md='glow'
alias ps='procs'
alias lzd='lazydocker'
# --- end tool replacements ---

# --- Utility ---
alias reload='source ~/.zshrc'
alias path='echo $PATH | tr ":" "\n"'
alias localip='ifconfig en0 | grep "inet " | awk "{print \$2}"'
# --- end utility ---

# --- Dashboard companions ---
# Jump to project N from the dashboard's recent projects list
p() {
  local projects_dir="$HOME/Developer/Projects"
  [[ -d "$projects_dir" ]] || { echo "Projects directory not found"; return 1; }
  local target=$(for dir in "$projects_dir"/*/; do
    [[ -d "$dir" ]] && stat -f "%m %N" "$dir"
  done | sort -rn | sed -n "${1:-1}p" | cut -d' ' -f2-)
  [[ -n "$target" ]] && cd "$target" || echo "Project $1 not found"
}

# Show a random tip, optionally filtered by category
tip() {
  local tips_file="$HOME/.config/zsh/tips/tips.json"
  [[ -f "$tips_file" ]] || { echo "Tips file not found"; return 1; }
  command -v jq &>/dev/null || { echo "jq required"; return 1; }

  local RST=$'\e[0m' BOLD=$'\e[1m'
  local GREEN=$'\e[38;2;166;218;149m' YELLOW=$'\e[38;2;238;212;159m'
  local MAUVE=$'\e[38;2;198;160;246m' PEACH=$'\e[38;2;245;169;127m'
  local SUBTEXT=$'\e[38;2;165;173;203m'

  local tip count
  if [[ -n "$1" ]]; then
    count=$(jq -r --arg cat "$1" '[.[] | select(.category == $cat)] | length' "$tips_file")
    (( count == 0 )) && { echo "No tips for category: $1 (try: unix, vim, zsh, fzf, git, tools, zellij)"; return 1; }
    local idx=$(( RANDOM % count ))
    tip=$(jq -r --arg cat "$1" --argjson idx "$idx" '[.[] | select(.category == $cat)][$idx]' "$tips_file")
  else
    count=$(jq 'length' "$tips_file")
    tip=$(jq ".[$((RANDOM % count))]" "$tips_file")
  fi

  local category=$(echo "$tip" | jq -r '.category')
  local title=$(echo "$tip" | jq -r '.title')
  local cmd=$(echo "$tip" | jq -r '.command')
  local explanation=$(echo "$tip" | jq -r '.explanation')

  printf "\n  ${MAUVE}[%s]${RST} ${BOLD}${YELLOW}%s${RST}\n" "$category" "$title"
  printf "  ${GREEN}%s${RST}\n" "$cmd"
  printf "  ${SUBTEXT}%s${RST}\n\n" "$explanation"
}
# --- end dashboard companions ---

